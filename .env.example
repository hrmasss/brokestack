# ==============================================================================
# ENVIRONMENT
# ==============================================================================
NODE_ENV=development
GO_ENV=development

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_HOST=localhost
API_PORT=8080
API_PREFIX=/api/v1

# ==============================================================================
# DATABASE
# ==============================================================================
DATABASE_URL=postgres://postgres:postgres@localhost:5432/brokestack?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
DATABASE_MAX_IDLE_CONNECTIONS=5

# ==============================================================================
# FRONTEND
# ==============================================================================
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=BrokeStack

# ==============================================================================
# AUTH (future)
# ==============================================================================
JWT_SECRET=brokestack-local-dev-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
AUTH_CUSTOMER_REFRESH_COOKIE=brokestack_customer_refresh
AUTH_PLATFORM_REFRESH_COOKIE=brokestack_platform_refresh
AUTH_COOKIE_SECURE=false

# Bootstrap the first super admin if no super admin exists yet
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@brokestack.app
BOOTSTRAP_ADMIN_PASSWORD=changeme123

# ==============================================================================
# AI/LLM CONFIGURATION (future)
# ==============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ==============================================================================
# PYTHON WORKER
# ==============================================================================
WORKER_URL=http://localhost:8091
WORKER_HOST=127.0.0.1
WORKER_PORT=8091
WORKER_ENV=development
WORKER_POLL_INTERVAL_SECONDS=5

# ==============================================================================
# TOOL / PROVIDER INTEGRATIONS (future)
# ==============================================================================
# PLAYWRIGHT_HEADLESS=true
# DOMAINS_PROVIDER_KEY=
# IMAGE_PROVIDER_KEY=

# ==============================================================================
# REDIS (optional caching & queues)
# ==============================================================================
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# STORAGE (future)
# ==============================================================================
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
